[
  {
    "version": "v0.9",
    "createSurface": {
      "surfaceId": "fixture_form",
      "catalogId": "https://a2ui.org/specification/v0_9/standard_catalog.json"
    }
  },
  {
    "version": "v0.9",
    "updateComponents": {
      "surfaceId": "fixture_form",
      "components": [
        {
          "id": "root",
          "component": "Column",
          "children": ["form-card"],
          "align": "stretch",
          "styles": {
            "padding": "20px",
            "background-color": "#F5F5F5"
          }
        },
        {
          "id": "form-card",
          "component": "Card",
          "child": "form-content",
          "styles": {
            "width": "auto",
            "padding": "24px",
            "border-radius": "16px",
            "background-color": "#FFFFFF",
            "filter": "drop-shadow(0px 6px 24px 0px rgba(0, 0, 0, 0.08))"
          }
        },
        {
          "id": "form-content",
          "component": "Column",
          "children": ["form-title", "name-field", "phone-field", "agree-check", "submit-btn"],
          "align": "stretch",
          "styles": { "gap": "16px" }
        },
        {
          "id": "form-title",
          "component": "Text",
          "text": "用户注册",
          "variant": "h2"
        },
        {
          "id": "name-field",
          "component": "TextField",
          "label": "姓名",
          "placeholder": "请输入您的姓名",
          "value": ""
        },
        {
          "id": "phone-field",
          "component": "TextField",
          "label": "手机号",
          "placeholder": "请输入手机号",
          "value": ""
        },
        {
          "id": "agree-check",
          "component": "CheckBox",
          "label": "同意服务条款",
          "value": false
        },
        {
          "id": "submit-btn",
          "component": "Button",
          "text": "提交",
          "variant": "primary",
          "action": {
            "functionCall": {
              "call": "toast",
              "args": { "value": "提交成功！" }
            }
          }
        }
      ]
    }
  },
  {}
]
