<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#6200EE"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="A2UI Text Demo"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSdkVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFCC"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#FFFFFF">

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="输入文本，如：天气、设置、表单、列表..."
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="3"
            android:inputType="text"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnGenerate"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="生成 UI"
            android:textSize="16sp"
            android:backgroundTint="#6200EE"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Controls row: Provider, Fixture, Streaming -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spinnerProvider"
                android:layout_width="wrap_content"
                android:layout_height="36dp" />

            <Spinner
                android:id="@+id/spinnerFixture"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/spinnerCardFixture"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:visibility="gone" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchStreaming"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Stream"
                android:textSize="12sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etLlmUrl"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:hint="LLM endpoint URL"
            android:text="http://10.0.2.2:8787/generate-ui"
            android:textSize="12sp"
            android:visibility="gone"
            android:inputType="textUri"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etProxyToken"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:hint="Proxy token (optional)"
            android:textSize="12sp"
            android:visibility="gone"
            android:inputType="textPassword"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- AGenUI render area -->
    <FrameLayout
        android:id="@+id/renderArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="300dp"
        android:background="#F5F5F5"
        android:padding="8dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Debug info area -->
    <LinearLayout
        android:id="@+id/debugContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F0F0F0">

        <!-- Debug header -->
        <LinearLayout
            android:id="@+id/debugHeader"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#DDDDDD"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Debug"
                android:textSize="13sp"
                android:textColor="#444444" />

            <TextView
                android:id="@+id/tvValidationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IDLE"
                android:textSize="11sp"
                android:textColor="#999999"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/tvDebugToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Debug content (collapsible) -->
        <LinearLayout
            android:id="@+id/debugContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="visible">

            <!-- Provider & Input row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDebugProvider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Provider: Mock"
                    android:textSize="11sp"
                    android:textColor="#444444" />

                <TextView
                    android:id="@+id/tvDebugInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Input: -"
                    android:textSize="11sp"
                    android:textColor="#444444" />
            </LinearLayout>

            <!-- Render status -->
            <TextView
                android:id="@+id/tvDebugRenderStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Render: idle"
                android:textSize="11sp"
                android:textColor="#444444"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <!-- SSE debug views (visible only for LLM + Stream) -->
            <TextView
                android:id="@+id/tvDebugSseStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#6200EE"
                android:visibility="gone"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tvDebugSseLastChunk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#666666"
                android:fontFamily="monospace"
                android:visibility="gone"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/tvDebugSseAccumulated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#333333"
                android:fontFamily="monospace"
                android:background="#FAFAFA"
                android:padding="4dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Raw JSON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="JSON"
                    android:textSize="11sp"
                    android:textColor="#444444" />

                <Button
                    android:id="@+id/btnCopyJson"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="复制"
                    android:textSize="14sp"
                    android:backgroundTint="#6200EE"
                    android:textColor="#FFFFFF"
                    android:minWidth="64dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <EditText
                android:id="@+id/tvDebugRawJson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#333333"
                android:fontFamily="monospace"
                android:background="#FAFAFA"
                android:padding="6dp"
                android:maxLines="30"
                android:inputType="none"
                android:textIsSelectable="true"
                android:importantForAutofill="no" />

            <!-- Error area -->
            <TextView
                android:id="@+id/tvDebugErrors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#CC0000"
                android:visibility="gone"
                android:paddingTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Log area -->
    <LinearLayout
        android:id="@+id/logsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:id="@+id/logsHeader"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#EEEEEE"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Logs"
                android:textSize="13sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvLogsToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/logsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No logs yet"
                android:textSize="11sp"
                android:textColor="#999999" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

</ScrollView>
